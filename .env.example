## -- Repo Path --
GEMINI_FORK_DIR=

## -- LLM API Keys --
## Base URLs are NOT needed here — they come from config/models.default.json.
## If your are at a company (Samsung), setting OPENAI_API_KEY is usually sufficient, as the company proxy will route to the correct endpoints. Just set the keys and comment out the base URLs in models.default.json.
OPENAI_API_KEY=
# ANTHROPIC_API_KEY=
# OPENROUTER_API_KEY=

## -- Environment Detection --
## Controls which models appear in the picker.
## Values: CORP / PRODUCTION / DEVELOPMENT / DEV / HOME
## If you are at a company (Samsung), you don't need to set this. Just comment it out.
# A2G_LOCATION=

## -- Corporate Auth (CORP environment only) --
## Format for FALLBACK_API_KEY_1: system_name/dep_ticket
## These are for advanced features for developers. Usually you don't need to set this. Just comment it out.
# AD_ID=
# FALLBACK_API_KEY_1=

## -- Langfuse Telemetry (on-prem) --
## Set all 3 to auto-enable tracing. No data leaves your network.
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_BASE_URL=

## -- Telemetry Overrides (optional) --
## Uncomment to override Langfuse auto-config (recommended to leave these commented out if using Langfuse).:
# GEMINI_TELEMETRY_ENABLED=true
# GEMINI_TELEMETRY_OUTFILE=~/gemini-traces.json

## -- Debug (optional) --
## If this is set, Gemini will log additional debug info to the specified file.
## Recommended to leave this commented out unless you're debugging an issue, as it can log sensitive info and grow large.
# GEMINI_DEBUG_LOG_FILE=~/gemini_debug.log

## -- SSL (corporate networks) --
## If you are at a company (Samsung) and have issues with SSL, you may need to set these. Just comment them out if you don't need them.
VERIFY_SSL=false
SSL_CERT_FILE=/etc/ssl/certs/ca-certificates.crt
