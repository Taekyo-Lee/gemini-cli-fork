{
  "_comment": "Model registry for gemini-cli fork. Copy to models.default.json and edit.",
  "_docs": "See docs/fork/architecture/dynamic-model-loading.md for field reference.",
  "_note_for_company": "If you are at a company (Samsung), you can leave corp/home/dev as-is. The company proxy handles routing — all models are available regardless of these flags. These flags are mainly for personal (non-company) setups where you want to filter models by environment.",

  "models": [

    { "_section": "--- OpenAI-compatible (on-prem vLLM, LiteLLM, etc.) ---" },
    {
      "model": "[On-Prem] your-model-name",
      "modelAlias": "actual-model-id-on-server",
      "url": "http://your-vllm-server:8000/v1",
      "modality": { "input": ["text"], "output": ["text"] },
      "contextLength": 128000,
      "maxTokens": 128000,
      "corp": true,
      "home": false,
      "dev": false
    },

    { "_section": "--- OpenAI ---" },
    {
      "model": "[OpenAI] gpt-4o",
      "modelAlias": "gpt-4o",
      "url": "https://api.openai.com/v1",
      "modality": { "input": ["text", "image"], "output": ["text"] },
      "contextLength": 128000,
      "maxCompletionTokens": 16384,
      "corp": false,
      "home": true,
      "dev": true
    },

    { "_section": "--- Anthropic ---" },
    {
      "model": "[Anthropic] claude-sonnet-4-6",
      "modelAlias": "claude-sonnet-4-6",
      "url": "https://api.anthropic.com/v1",
      "modality": { "input": ["text", "image"], "output": ["text"] },
      "contextLength": 1000000,
      "maxTokens": 64000,
      "corp": false,
      "home": true,
      "dev": true
    },

    { "_section": "--- OpenRouter ---" },
    {
      "model": "[OpenRouter] deepseek-v3.2",
      "modelAlias": "deepseek/deepseek-v3.2",
      "url": "https://openrouter.ai/api/v1",
      "modality": { "input": ["text"], "output": ["text"] },
      "contextLength": 128000,
      "maxTokens": 128000,
      "corp": false,
      "home": true,
      "dev": true
    }

  ]
}
